# Copy this file to .env and fill in your real values.
# .env is git-ignored and stays only on this machine.

# Google Gemini API key (starts with AQ. or AIza)
GEMINI_API_KEY=

# Perplexity API key (optional — leave blank to skip)
PERPLEXITY_API_KEY=

# the-odds-api.com — real live bookmaker odds (PRIMARY odds source, no Gemini quota).
# Free key (500 req/month) from https://the-odds-api.com/ . Blank = fall back to Gemini.
ODDS_API_KEY=
# Optional overrides (defaults shown): sport key + regions for the odds query.
# ODDS_API_SPORT=soccer_fifa_world_cup
# ODDS_API_REGIONS=eu,uk

# Telegram (preferred delivery). Token from @BotFather, chat_id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gmail sending (optional fallback — use a Gmail App Password, NOT your normal password)
GMAIL_ADDRESS=yotamfogel@gmail.com
GMAIL_APP_PASSWORD=
MAIL_TO=yotamfogel@gmail.com

# Public URL where the HTML report is published (GitHub Pages)
REPORT_PUBLIC_URL=
